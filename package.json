{
  "name": "agent-ready-mcp",
  "version": "0.4.1",
  "mcpName": "io.github.mlava/agent-ready-mcp",
  "description": "MCP server for Agent Ready — scan any URL for AI-readability against the Vercel Agent Readability Spec, the llmstxt.org standard, and agent-protocol manifests (MCP server cards, A2A, agents.json, agent-permissions.json, UCP, x402, NLWeb). 60 checks with per-check fix guidance.",
  "license": "MIT",
  "author": "Agent Ready",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlava/agent-ready-mcp.git"
  },
  "homepage": "https://agent-ready.dev",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "seo",
    "ai-search",
    "llms-txt",
    "agents.md",
    "agent-readability",
    "scanner",
    "validator",
    "vercel-spec",
    "mcp-server-card",
    "a2a",
    "agents-json",
    "agent-permissions",
    "ucp",
    "x402",
    "claude"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "agent-ready-mcp": "dist/mcp-server.mjs"
  },
  "files": [
    "dist/mcp-server.mjs",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.25.8",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}
